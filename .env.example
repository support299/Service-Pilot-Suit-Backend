# ─────────────────────────────────────────────────────────────
# Service Pilot Suite — Backend environment
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Core Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/service_pilot_suite

# --- CORS (frontend origins allowed to call the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- GoHighLevel Marketplace App (OAuth) ---
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_VERSION_ID=
# Must match the marketplace app redirect URI EXACTLY (trailing slash matters).
GHL_REDIRECT_URI=http://localhost:8000/api/auth/crm/callback/
# Space-separated scopes
GHL_SCOPES=opportunities.readonly opportunities.write locations.readonly contacts.readonly contacts.write medias.readonly medias.write pipelines.readonly pipelines.write pipelines.create users.readonly adPublishing.readonly adPublishing.write campaigns.readonly locations/customFields.readonly locations/customFields.write
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# --- Auto-login trust ---
GHL_AUTOLOGIN_SHARED_SECRET=

# --- Frontend base (for building redirect URLs after OAuth) ---
FRONTEND_BASE_URL=http://localhost:5173
